---
import { services, ui, type Locale } from "../data/content";

interface Props { locale: Locale }
const { locale } = Astro.props;
const copy = ui[locale];
const base = import.meta.env.BASE_URL;
const prefix = locale === "de" ? "/de" : "";
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<div class="service-grid">
  {services[locale].map((service, index) => (
    <article class="service-card">
      <a class="service-card__image" href={withBase(`${prefix}/solutions/${service.slug}/`)} aria-label={`${copy.viewService}: ${service.shortTitle}`}>
        <img src={`${base}images/${service.cardImage}`} width="640" height="320" loading={index === 0 ? "eager" : "lazy"} alt="" />
        <span class="service-card__number" aria-hidden="true">0{index + 1}</span>
      </a>
      <div class="service-card__body">
        <h3><a href={withBase(`${prefix}/solutions/${service.slug}/`)}>{service.shortTitle}</a></h3>
        <p>{service.cardText}</p>
        <a class="text-link" href={withBase(`${prefix}/solutions/${service.slug}/`)}>{copy.viewService} <span aria-hidden="true">→</span></a>
      </div>
    </article>
  ))}
</div>

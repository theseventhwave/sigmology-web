---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { PageData } from "../data/content";

interface Props {
  page: PageData;
  noindex?: boolean;
}

const { page, noindex = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
const canonical = new URL(withBase(page.path), Astro.site);
const alternate = new URL(withBase(page.alternatePath), Astro.site);
const englishUrl = page.locale === "en" ? canonical : alternate;
const germanUrl = page.locale === "de" ? canonical : alternate;
const fullTitle = page.kind === "home" ? `${page.title} | Sigmology` : `${page.title} | Sigmology`;
const socialImage = new URL(`${base}images/home-hero.webp`, Astro.site);
---

<!doctype html>
<html lang={page.locale === "de" ? "de-CH" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={page.description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    {!noindex && <link rel="canonical" href={canonical} />}
    {!noindex && <link rel="alternate" hreflang="en" href={englishUrl} />}
    {!noindex && <link rel="alternate" hreflang="de-CH" href={germanUrl} />}
    {!noindex && <link rel="alternate" hreflang="x-default" href={englishUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sigmology" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={page.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content={page.locale === "de" ? "de_CH" : "en_GB"} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{page.locale === "de" ? "Zum Inhalt springen" : "Skip to content"}</a>
    <Header locale={page.locale} path={page.path} alternatePath={page.alternatePath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={page.locale} />
  </body>
</html>
